# Supabase Konfiguration
# Kopiere diese Datei als .env und trage deine Werte ein

# Supabase Projekt-ID (zu finden im Supabase Dashboard unter Project Settings)
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Supabase API URL
# Lokal (nach 'supabase start'): http://127.0.0.1:54321
# Cloud:                         https://<project-id>.supabase.co
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase Publishable (anon) Key
# Lokal: Ausgabe von 'supabase status' -> Publishable
# Cloud: Supabase Dashboard -> Project Settings -> API -> anon key
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
